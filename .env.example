# Modelo de variáveis de ambiente. Copie para `.env` e preencha.
# O arquivo `.env` é IGNORADO pelo git (ver .gitignore) — NUNCA comite a chave real.
#
# Carregar no shell antes de rodar a pipeline/coletores:
#   set -a; source .env; set +a
#
# Chave gratuita da API do Portal da Transparência (enviada por header 'chave-api-dados').
# Gere a sua em: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
PORTAL_TRANSPARENCIA_API_KEY=
